generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Noticia {
  id         String   @id @default(uuid())
  titulo     String
  slug       String   @unique
  extracto   String?
  contenido  String?
  imagen     String?
  categoria  String   @default("General")
  fecha      DateTime @default(now())
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("noticias")
}

model Testimonio {
  id        String   @id @default(uuid())
  nombre    String
  cargo     String?
  texto     String
  estrellas Int      @default(5)
  color     String   @default("#1e3a5f")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("testimonios")
}

model Album {
  id          String      @id @default(uuid())
  titulo      String
  descripcion String?
  portada     String?
  orden       Int         @default(0)
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  fotos       FotoAlbum[]

  @@map("albums")
}

model Video {
  id        String   @id @default(uuid())
  titulo    String
  url       String
  anio      Int
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("videos")
}

model Documento {
  id         String   @id @default(uuid())
  titulo     String
  categoria  String   @default("Otro")
  anio       Int
  link       String
  activo     Boolean  @default(true)
  orden      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("documentos")
}

model Boletin {
  id        String   @id @default(uuid())
  titulo    String
  fecha     DateTime @default(now())
  link      String
  isPdf     Boolean  @default(true) @map("is_pdf")
  imagen    String?
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("boletines")
}

model FotoAlbum {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  orden     Int      @default(0)
  albumId   String   @map("album_id")
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("fotos_album")
}
